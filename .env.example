# Vite frontend environment variables
VITE_API_BASE_URL=/api

# Google OAuth credentials (also needed in .dev.vars for Wrangler local dev)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT secret for session tokens
WORKER_JWT_SECRET=change_this_to_a_random_secret_min_32_chars

# Frontend URL for OAuth callback redirects
FRONTEND_URL=http://localhost:5173

# Admin email
ADMIN_EMAIL=admin@example.com

# Optional conversion service URLs for local dev
CONVERTER_URL=
JWW_CONVERTER_URL=
